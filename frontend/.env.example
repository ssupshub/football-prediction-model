# ─────────────────────────────────────────────────────────────────
# Football Match Predictor — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# 
# ─────────────────────────────────────────────────────────────────
#
# Base URL of the backend API.
# Development: leave commented out — Vite proxy handles it automatically.
# Production: set to your deployed backend URL (no trailing slash).
# VITE_API_BASE_URL=https://your-backend.onrender.com

# Note: All frontend env vars MUST start with VITE_ to be
# accessible in the browser. Variables without this prefix
# are ignored by Vite at build time.
