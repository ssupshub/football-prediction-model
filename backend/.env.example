# ─────────────────────────────────────────────────────────────────
# Football Match Predictor — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Path to the trained model pickle file
MODEL_PATH=football_model.pkl

# Path to the saved ELO + team stats state file
STATE_PATH=current_state.pkl

# Comma-separated list of allowed frontend origins for CORS.
# Use * to allow all origins (only safe for development).
# Production example: https://your-app.vercel.app
ALLOWED_ORIGINS=*

# Port the uvicorn server listens on
PORT=8000
